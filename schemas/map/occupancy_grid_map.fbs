include "../common/header.fbs";
include "../geometry/geometry.fbs";

namespace vmsgs.fbs.map;

/// 2D static map tile. See perception.OccupancyGrid for the dynamic variant.
table OccupancyGridMap {
  header:vmsgs.fbs.common.Header (id: 0);
  resolution:float (id: 1);
  width:uint32 (id: 2);
  height:uint32 (id: 3);
  origin:vmsgs.fbs.geometry.Pose (id: 4);
  /// Row-major signed bytes; -1 unknown, 0 free, 100 occupied.
  data:[byte] (id: 5);
}

root_type OccupancyGridMap;
