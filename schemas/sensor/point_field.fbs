namespace vmsgs.fbs.sensor;

enum PointFieldType : ubyte {
  UNKNOWN = 0,
  INT8    = 1,
  UINT8   = 2,
  INT16   = 3,
  UINT16  = 4,
  INT32   = 5,
  UINT32  = 6,
  FLOAT32 = 7,
  FLOAT64 = 8,
}

/// Description of a single channel inside the packed point-cloud byte buffer.
table PointField {
  name:string         (id: 0);
  offset:uint32       (id: 1);
  datatype:PointFieldType (id: 2);
  count:uint32        (id: 3);
}
